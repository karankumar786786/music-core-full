{
  "expo": {
    "name": "One Melody",
    "slug": "one-melody",
    "version": "1.0.0",
    "icon": "./assets/image.png",
    "orientation": "portrait",
    "scheme": "my-expo-app",
    "splash": {
      "image": "./assets/image.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-video",
      "expo-font"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/image.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.oneorg6969.onemelody"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ca70e399-8c0b-44a7-89bf-63d7aac2c716"
      }
    }
  }
}